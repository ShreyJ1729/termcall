import json

with open("mapping.json", "r") as f:
    mapping: dict = json.load(f)


# create a linear scale from 0 to 1 with 128 values, and map the closest char to each value
scale_mapping = {}
for i in range(128):
    darkness = i / 128
    closest_char = min(mapping, key=lambda x: abs(mapping[x] - darkness))
    scale_mapping[darkness] = closest_char
    char_darkness = mapping[closest_char]
    eror_percent = abs(char_darkness - darkness) / (darkness + 0.0001) * 100
    try:
        print(
            f"{i} mapping for {darkness}: {closest_char}={char_darkness} (error: {eror_percent:.0f}%)"
        )
    except UnicodeEncodeError:
        print("error at char - replacing with NA")
        scale_mapping[darkness] = "NA"

# iterate in reverse and if a char is NA, replace it with the previous char
previous_char = None
for darkness in sorted(scale_mapping.keys(), reverse=True):
    char = scale_mapping[darkness]
    if char == "NA":
        scale_mapping[darkness] = previous_char
    else:
        previous_char = char

print(json.dumps(scale_mapping, indent=4))

# print out each char in the mapping
for darkness, char in sorted(scale_mapping.items()):
    try:
        print(char, end="")
    except UnicodeEncodeError:
        continue
